<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Gewichts-Selbsttest</title>
<style>
body {
  font-family: Arial;
  max-width: 600px;
  margin: 40px auto;
  padding: 20px;
}
button {
  display: block;
  margin: 10px 0;
  padding: 10px;
  width: 100%;
  cursor: pointer;
}
#result {
  margin-top: 30px;
  font-weight: bold;
}
</style>
</head>

<body>

<h1>Selbsttest Gewichtsregulation</h1>

<div id="quiz"></div>

<div id="result"></div>

<script>

let currentQuestion = 0;

let score = {
  ernaehrung: 0,
  bewegung: 0,
  stoffwechsel: 0,
  kompensation: 0,
  konditionierung: 0,
  hypnose: 0,
  gespraech: 0,
  meditation: 0
};

const questions = [

{
  text: "Wo siehst du den größten Hebel für dein Gewicht?",
  answers: [
    { text: "Ernährung", type: "ernaehrung" },
    { text: "Bewegung", type: "bewegung" },
    { text: "Stoffwechsel", type: "stoffwechsel" }
  ]
},

{
  text: "Was beeinflusst dein Verhalten am meisten?",
  answers: [
    { text: "Gefühle / Stress", type: "kompensation" },
    { text: "Gewohnheiten", type: "konditionierung" },
    { text: "Beides", type: "kompensation" }
  ]
},

{
  text: "Wie gehst du mit deinem Anliegen um?",
  answers: [
    { text: "Gefühlsbasiert", type: "hypnose" },
    { text: "Gedanklich", type: "gespraech" },
    { text: "Beobachtend", type: "meditation" }
  ]
}

];

function showQuestion() {
  const quiz = document.getElementById("quiz");
  quiz.innerHTML = "";

  if (currentQuestion >= questions.length) {
    showResult();
    return;
  }

  const q = questions[currentQuestion];

  const title = document.createElement("h2");
  title.innerText = q.text;
  quiz.appendChild(title);

  q.answers.forEach(answer => {
    const btn = document.createElement("button");
    btn.innerText = answer.text;
    btn.onclick = () => selectAnswer(answer.type);
    quiz.appendChild(btn);
  });
}

function selectAnswer(type) {
  score[type]++;
  currentQuestion++;
  showQuestion();
}

function getMaxCategory(categories) {
  return Object.keys(categories).reduce((a, b) =>
    categories[a] > categories[b] ? a : b
  );
}

function showResult() {

  const ansatz = getMaxCategory({
    ernaehrung: score.ernaehrung,
    bewegung: score.bewegung,
    stoffwechsel: score.stoffwechsel
  });

  const umgang = getMaxCategory({
    kompensation: score.kompensation,
    konditionierung: score.konditionierung
  });

  const bewusstsein = getMaxCategory({
    hypnose: score.hypnose,
    gespraech: score.gespraech,
    meditation: score.meditation
  });

  document.getElementById("quiz").innerHTML = "";
  document.getElementById("result").innerText =
    "Dein Ergebnis:\n" +
    ansatz + " → " + umgang + " → " + bewusstsein;
}

showQuestion();

</script>

</body>
</html>
